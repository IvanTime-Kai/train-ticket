# App: chọn file config (configs/<CONFIG_NAME>.yaml). App đọc MySQL/Server/Logger từ YAML, không từ .env.
CONFIG_NAME=local

# Makefile: dùng cho migrate (goose). MYSQL_DSN = $(MYSQL_USER):$(MYSQL_PASSWORD)@tcp($(MYSQL_HOST):$(MYSQL_PORT))/$(MYSQL_DBNAME)
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=app
MYSQL_PASSWORD=app123
MYSQL_DBNAME=train_db
