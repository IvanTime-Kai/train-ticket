    "definitions": {
        "github_com_leminhthai_train-ticket_train-service_internal_model.CreateRouteRequest": {
            "type": "object",
            "required": [
                "destination_station_id",
                "origin_station_id"
            ],
            "properties": {
                "destination_station_id": {
                    "type": "string"
                },
                "distance_km": {
                    "type": "integer"
                },
                "origin_station_id": {
                    "type": "string"
                }
            }
        },
        "github_com_leminhthai_train-ticket_train-service_internal_model.CreateSeatRequest": {
            "type": "object",
            "required": [
                "class",
                "price",
                "seat_number"
            ],
            "properties": {
                "class": {
                    "type": "string",
                    "enum": [
                        "economy",
                        "business",
                        "vip"
                    ]
                },
                "price": {
                    "type": "number",
                    "minimum": 0
                },
                "seat_number": {
                    "type": "string"
                }
            }
        },
        "github_com_leminhthai_train-ticket_train-service_internal_model.CreateStationRequest": {
            "type": "object",
            "required": [
                "city",
                "code",
                "name"
            ],
            "properties": {
                "city": {
                    "type": "string"
                },
                "code": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "github_com_leminhthai_train-ticket_train-service_internal_model.CreateTrainRequest": {
            "type": "object",
            "required": [
                "name",
                "total_seats"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "total_seats": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "github_com_leminhthai_train-ticket_train-service_internal_model.CreateTripRequest": {
            "type": "object",
            "required": [
                "arrival_time",
                "departure_time",
                "route_id",
                "train_id"
            ],
            "properties": {
                "arrival_time": {
                    "type": "string"
                },
                "departure_time": {
                    "description": "format: 2006-01-02 15:04:05",
                    "type": "string"
                },
                "route_id": {
                    "type": "string"
                },
                "train_id": {
                    "type": "string"
                }
            }
        },
        "github_com_leminhthai_train-ticket_train-service_pkg_response.ResponseData": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {},
                "message": {
                    "type": "string"
                }
            }
        }
    },
